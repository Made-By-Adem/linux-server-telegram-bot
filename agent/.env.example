# Linux Server Bot API - Agent Environment Variables
#
# Configure one block per server you want to manage.
# The agent uses these to authenticate with each server's API.

# Server 1
SERVER_1_NAME=homelab
SERVER_1_URL=https://api-homelab.example.com/api
SERVER_1_API_KEY=your-api-key-here

# Server 2 (optional - add as many as needed)
# SERVER_2_NAME=vps-production
# SERVER_2_URL=https://api-vps.example.com/api
# SERVER_2_API_KEY=your-api-key-here

# Server 3 (optional - local network)
# SERVER_3_NAME=raspberry-pi
# SERVER_3_URL=http://192.168.1.100:8120/api
# SERVER_3_API_KEY=your-api-key-here
